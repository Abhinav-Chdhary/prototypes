# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in cases where the lock file contains system-dependent dependencies, it may need to be ignored.
#  Pipfile.lock

# poetry
#   Similar to Pipenv, it is generally recommended to include poetry.lock in version control.
#   poetry.lock

# pdm
#   Similar to Pipenv, it is generally recommended to include pdm.lock in version control.
# pdm.lock
# pdm.toml
# .pdm-python

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

